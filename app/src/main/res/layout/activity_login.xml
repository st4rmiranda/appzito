<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A0033"> <!-- Cor roxa escura idêntica ao vídeo -->

    <!-- Animação Lottie (JSON) -->
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottieAnimation"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:lottie_rawRes="@raw/animacao_estudo"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        android:scaleType="fitCenter"
        android:layout_margin="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="32dp"> <!-- Removi o gravity:center daqui -->

        <!-- Este View serve como uma mola (Space) que empurra o título -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:fontFamily="@font/adelia"
            android:text="STUBLE"
            android:textColor="#FFFFFF"
            android:textSize="50sp"
            android:textStyle="bold" />

        <!-- Este View é a mola principal que empurra os botões para o final da tela -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="2" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoogleLogin"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="ENTRAR COM GOOGLE"
            android:backgroundTint="#FFFFFF"
            android:textColor="#1A0033"
            app:cornerRadius="30dp"
            app:icon="@drawable/ic_google"
            app:iconGravity="textStart"
            app:iconTint="@null"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEmailLogin"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="12dp"
            android:text="USAR E-MAIL"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/txtIrParaCadastro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NÃO TEM CONTA? CADASTRE-SE"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp"
            android:padding="8dp"
            android:layout_marginBottom="20dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>