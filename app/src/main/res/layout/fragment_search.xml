<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    tools:context=".SearchFragment">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- CABEÇALHO -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="245dp"
                android:background="#4F46E5"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingTop="42dp"
                android:paddingEnd="24dp"
                android:paddingBottom="52dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="QUESTÕES E CONTEÚDOS"
                    android:textColor="#C7D2FE"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Encontre seu próximo foco 📚"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="2dp"
                    android:text="Pesquise um assunto específico ou escolha uma área para praticar."
                    android:textColor="#E0E7FF"
                    android:textSize="15sp" />
            </LinearLayout>

            <!-- BARRA DE PESQUISA SOBREPOSTA -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginStart="20dp"
                android:layout_marginTop="-34dp"
                android:layout_marginEnd="20dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="22dp"
                app:cardElevation="7dp"
                app:strokeColor="#E2E8F0"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:id="@+id/containerBarra"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="18dp"
                    android:paddingEnd="12dp">

                    <ImageView
                        android:layout_width="23dp"
                        android:layout_height="23dp"
                        android:contentDescription="Pesquisar"
                        android:src="@drawable/ic_search"
                        app:tint="#4F46E5" />

                    <EditText
                        android:id="@+id/etPesquisa"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:hint="Ex: Bhaskara, crase, mitose..."
                        android:imeOptions="actionSearch"
                        android:inputType="text"
                        android:padding="0dp"
                        android:singleLine="true"
                        android:textColor="#0F172A"
                        android:textColorHint="#94A3B8"
                        android:textSize="15sp" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        app:cardBackgroundColor="#EEF2FF"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp">

                        <ImageView
                            android:id="@+id/btnPesquisar"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:contentDescription="Buscar assunto"
                            android:src="@drawable/ic_search"
                            app:tint="#4F46E5" />
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="25dp"
                android:paddingEnd="20dp"
                android:paddingBottom="42dp">

                <!-- RECOMENDADO -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✨ RECOMENDADO PARA VOCÊ"
                    android:textColor="#4F46E5"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardRecomendado"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="11dp"
                    app:cardBackgroundColor="#4F46E5"
                    app:cardCornerRadius="26dp"
                    app:cardElevation="3dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="50dp"
                                android:layout_height="50dp"
                                android:gravity="center"
                                android:text="🎯"
                                android:textSize="29sp" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/txtRecomendacaoTitulo"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Matemática • Intermediário"
                                    android:textColor="#FFFFFF"
                                    android:textSize="18sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/txtRecomendacaoDescricao"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="Reforce conteúdos importantes para sua meta."
                                    android:textColor="#E0E7FF"
                                    android:textSize="13sp" />
                            </LinearLayout>
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnComecarRecomendado"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="17dp"
                            android:text="COMEÇAR AGORA"
                            android:textColor="#4338CA"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            app:backgroundTint="#FFFFFF"
                            app:cornerRadius="16dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- BUSCAS POPULARES -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="27dp"
                    android:text="Buscas populares"
                    android:textColor="#0F172A"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="Toque em um tema para pesquisar rapidamente."
                    android:textColor="#64748B"
                    android:textSize="13sp" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:clipToPadding="false"
                    android:overScrollMode="never"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingEnd="8dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/chipBhaskara"
                            android:layout_width="wrap_content"
                            android:layout_height="46dp"
                            android:layout_marginEnd="8dp"
                            android:text="Bhaskara"
                            android:textAllCaps="false"
                            android:textColor="#4F46E5"
                            app:backgroundTint="#EEF2FF"
                            app:cornerRadius="15dp"
                            app:strokeColor="#C7D2FE"
                            app:strokeWidth="1dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/chipMitose"
                            android:layout_width="wrap_content"
                            android:layout_height="46dp"
                            android:layout_marginEnd="8dp"
                            android:text="Mitose"
                            android:textAllCaps="false"
                            android:textColor="#15803D"
                            app:backgroundTint="#F0FDF4"
                            app:cornerRadius="15dp"
                            app:strokeColor="#BBF7D0"
                            app:strokeWidth="1dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/chipCrase"
                            android:layout_width="wrap_content"
                            android:layout_height="46dp"
                            android:layout_marginEnd="8dp"
                            android:text="Crase"
                            android:textAllCaps="false"
                            android:textColor="#0F766E"
                            app:backgroundTint="#ECFEFF"
                            app:cornerRadius="15dp"
                            app:strokeColor="#A5F3FC"
                            app:strokeWidth="1dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/chipRevolucao"
                            android:layout_width="wrap_content"
                            android:layout_height="46dp"
                            android:text="Revolução Francesa"
                            android:textAllCaps="false"
                            android:textColor="#C2410C"
                            app:backgroundTint="#FFF7ED"
                            app:cornerRadius="15dp"
                            app:strokeColor="#FED7AA"
                            app:strokeWidth="1dp" />
                    </LinearLayout>
                </HorizontalScrollView>

                <!-- ÁREAS -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:text="Áreas do conhecimento"
                    android:textColor="#0F172A"
                    android:textSize="19sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:layout_marginBottom="14dp"
                    android:text="Escolha uma área para treinar questões específicas."
                    android:textColor="#64748B"
                    android:textSize="13sp" />

                <!-- LINGUAGENS -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardLinguagens"
                    android:layout_width="match_parent"
                    android:layout_height="128dp"
                    android:layout_marginBottom="13dp"
                    app:cardBackgroundColor="#E0F7FA"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#B2EBF2"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="18dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="58dp"
                            android:layout_height="58dp"
                            app:cardBackgroundColor="#FFFFFF"
                            app:cardCornerRadius="18dp"
                            app:cardElevation="0dp">

                            <ImageView
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:layout_gravity="center"
                                android:contentDescription="Linguagens"
                                android:src="@drawable/ic_book"
                                app:tint="#00838F" />
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="15dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Linguagens e Códigos"
                                android:textColor="#006064"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Português, literatura, interpretação e idiomas"
                                android:textColor="#0F766E"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/txtProgressoLinguagens"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="7dp"
                                android:text="Comece a praticar esta área"
                                android:textColor="#00838F"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:gravity="center"
                            android:text="›"
                            android:textColor="#00838F"
                            android:textSize="29sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- MATEMÁTICA -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardExatas"
                    android:layout_width="match_parent"
                    android:layout_height="128dp"
                    android:layout_marginBottom="13dp"
                    app:cardBackgroundColor="#FFEBEE"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#FFCDD2"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="18dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="58dp"
                            android:layout_height="58dp"
                            app:cardBackgroundColor="#FFFFFF"
                            app:cardCornerRadius="18dp"
                            app:cardElevation="0dp">

                            <ImageView
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:layout_gravity="center"
                                android:contentDescription="Matemática"
                                android:src="@drawable/ic_calculate"
                                app:tint="#D32F2F" />
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="15dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Matemática e Exatas"
                                android:textColor="#B71C1C"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Matemática, cálculos e raciocínio lógico"
                                android:textColor="#C62828"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/txtProgressoExatas"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="7dp"
                                android:text="Comece a praticar esta área"
                                android:textColor="#D32F2F"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:gravity="center"
                            android:text="›"
                            android:textColor="#D32F2F"
                            android:textSize="29sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- NATUREZA -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardBiologia"
                    android:layout_width="match_parent"
                    android:layout_height="128dp"
                    android:layout_marginBottom="13dp"
                    app:cardBackgroundColor="#E8F5E9"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#C8E6C9"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="18dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="58dp"
                            android:layout_height="58dp"
                            app:cardBackgroundColor="#FFFFFF"
                            app:cardCornerRadius="18dp"
                            app:cardElevation="0dp">

                            <ImageView
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:layout_gravity="center"
                                android:contentDescription="Ciências da Natureza"
                                android:src="@drawable/ic_biotech"
                                app:tint="#2E7D32" />
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="15dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Ciências da Natureza"
                                android:textColor="#1B5E20"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Biologia, física e química"
                                android:textColor="#2E7D32"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/txtProgressoNatureza"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="7dp"
                                android:text="Comece a praticar esta área"
                                android:textColor="#388E3C"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:gravity="center"
                            android:text="›"
                            android:textColor="#2E7D32"
                            android:textSize="29sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- HUMANAS -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardHumanas"
                    android:layout_width="match_parent"
                    android:layout_height="128dp"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="#FFF9C4"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#FFF59D"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="18dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="58dp"
                            android:layout_height="58dp"
                            app:cardBackgroundColor="#FFFFFF"
                            app:cardCornerRadius="18dp"
                            app:cardElevation="0dp">

                            <ImageView
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:layout_gravity="center"
                                android:contentDescription="Ciências Humanas"
                                android:src="@drawable/ic_public"
                                app:tint="#F57F17" />
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="15dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Ciências Humanas"
                                android:textColor="#E65100"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="História, geografia, filosofia e sociologia"
                                android:textColor="#F57F17"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/txtProgressoHumanas"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="7dp"
                                android:text="Comece a praticar esta área"
                                android:textColor="#F57F17"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:gravity="center"
                            android:text="›"
                            android:textColor="#F57F17"
                            android:textSize="29sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>